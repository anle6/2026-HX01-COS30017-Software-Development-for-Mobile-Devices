<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SupercarButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/supercar_button_bg</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="SectionHeader">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:textColor">@color/supercar_accent_gold</item>
    </style>

    <style name="CarDetailValue">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>
</resources>
